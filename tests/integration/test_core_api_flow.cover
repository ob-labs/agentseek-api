    1: def test_assistants_threads_runs_flow(client: TestClient) -> None:
    1:     assistant_resp = client.post("/assistants", json={"name": "demo", "graph_id": "default"})
    1:     assert assistant_resp.status_code == 200
    1:     assistant_id = assistant_resp.json()["assistant_id"]
       
    1:     thread_resp = client.post("/threads", json={"metadata": {"topic": "test"}})
    1:     assert thread_resp.status_code == 200
    1:     thread_id = thread_resp.json()["thread_id"]
       
    2:     run_resp = client.post(
    1:         f"/threads/{thread_id}/runs",
    1:         json={"assistant_id": assistant_id, "input": {"message": "hello"}},
           )
    1:     assert run_resp.status_code == 200
    1:     run_id = run_resp.json()["run_id"]
       
    1:     wait_resp = client.get(f"/threads/{thread_id}/runs/{run_id}/wait")
    1:     assert wait_resp.status_code == 200
    1:     assert wait_resp.json()["status"] in {"success", "error"}
       
    1:     list_resp = client.get(f"/threads/{thread_id}/runs")
    1:     assert list_resp.status_code == 200
    1:     assert len(list_resp.json()) == 1
       
       
    1: def test_stateless_run_creates_thread_and_run(client: TestClient) -> None:
    1:     assistant_resp = client.post("/assistants", json={"name": "stateless", "graph_id": "default"})
    1:     assert assistant_resp.status_code == 200
    1:     assistant_id = assistant_resp.json()["assistant_id"]
       
    1:     run_resp = client.post("/runs", json={"assistant_id": assistant_id, "input": {"foo": "bar"}})
