    1: import asyncio
    1: from collections import defaultdict
    1: from collections.abc import AsyncIterator
       
       
    2: class RunEventBroker:
    1:     def __init__(self) -> None:
    1:         self._events: dict[str, list[str]] = defaultdict(list)
    1:         self._signals: dict[str, asyncio.Event] = defaultdict(asyncio.Event)
       
    1:     def publish(self, run_id: str, event: str) -> None:
    2:         self._events[run_id].append(event)
    2:         self._signals[run_id].set()
       
    1:     def snapshot(self, run_id: str) -> list[str]:
               return list(self._events.get(run_id, []))
       
    1:     async def stream(self, run_id: str) -> AsyncIterator[str]:
               seen = 0
               while True:
                   events = self._events.get(run_id, [])
                   while seen < len(events):
                       event = events[seen]
                       seen += 1
                       yield event
                       if event == "end":
                           return
                   signal = self._signals[run_id]
                   signal.clear()
                   await signal.wait()
       
       
    1: run_broker = RunEventBroker()
