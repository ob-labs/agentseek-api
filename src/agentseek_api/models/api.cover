    1: from datetime import datetime
    1: from typing import Any
       
    1: from pydantic import BaseModel, Field
       
       
    2: class AssistantCreate(BaseModel):
    1:     name: str
    1:     graph_id: str = "default"
       
       
    2: class AssistantRead(BaseModel):
    1:     assistant_id: str
    1:     name: str
    1:     graph_id: str
    1:     created_at: datetime
       
       
    2: class ThreadCreate(BaseModel):
    1:     metadata: dict[str, Any] = Field(default_factory=dict)
       
       
    2: class ThreadRead(BaseModel):
    1:     thread_id: str
    1:     user_id: str
    1:     metadata: dict[str, Any]
    1:     created_at: datetime
       
       
    2: class RunCreate(BaseModel):
